---
const categories = [
  { name: 'Landing Pages', count: 24, icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2zm0 8a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2z', gradient: 'from-blue-500 to-cyan-400' },
  { name: 'E-Commerce', count: 18, icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z', gradient: 'from-purple-500 to-pink-400' },
  { name: 'Dashboards', count: 12, icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', gradient: 'from-violet-500 to-indigo-400' },
  { name: 'Mobile Apps', count: 31, icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', gradient: 'from-green-500 to-emerald-400' },
  { name: 'SaaS Platforms', count: 15, icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', gradient: 'from-orange-500 to-amber-400' },
  { name: 'Booking Systems', count: 9, icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', gradient: 'from-rose-500 to-pink-400' }
];
---

<section id="services" class="py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-end justify-between mb-16" data-animate>
      <div>
        <h2 class="text-4xl md:text-5xl font-bold font-display tracking-tight">
          Design patterns<br/>we master
        </h2>
      </div>
      <a href="#contact" class="hidden md:inline-flex items-center gap-2 text-sm text-text-secondary hover:text-text transition-colors group">
        View all services
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" data-animate>
      {categories.map((cat) => (
        <a href="#contact" class="group bg-bg-surface border border-border rounded-xl p-6 hover:border-accent/30 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${cat.gradient} flex items-center justify-center shrink-0`}>
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={cat.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold font-display mb-1">{cat.name}</h3>
              <p class="text-sm text-text-muted">{cat.count} templates</p>
            </div>
            <svg class="w-4 h-4 text-text-muted group-hover:text-accent transition-colors mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
