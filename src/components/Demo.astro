<script>
  const tabs = document.querySelectorAll('.demo-tab');
  const panels = document.querySelectorAll('.demo-panel');
  const urlDisplay = document.getElementById('demo-url');
  const restaurantBg = document.getElementById('restaurant-bg') as HTMLImageElement;

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const demoId = tab.getAttribute('data-demo');

      tabs.forEach((t) => {
        t.classList.remove('bg-accent', 'text-white');
        t.classList.add('text-text-secondary', 'border', 'border-border');
      });
      tab.classList.add('bg-accent', 'text-white');
      tab.classList.remove('text-text-secondary', 'border', 'border-border');

      panels.forEach((p) => p.classList.add('hidden'));
      const target = document.getElementById(`demo-${demoId}`);
      if (target) target.classList.remove('hidden');

      if (urlDisplay) urlDisplay.textContent = demoId + '-demo';
    });
  });

  const restaurantScene = document.getElementById('restaurant-scene');
  if (restaurantScene && restaurantBg) {
    restaurantScene.addEventListener('mousemove', (e: any) => {
      const rect = restaurantScene.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      restaurantBg.style.transform = `scale(1.15) translate(${x * -25}px, ${y * -25}px)`;
    });

    restaurantScene.addEventListener('mouseleave', () => {
      restaurantBg.style.transform = 'scale(1.15) translate(0, 0)';
    });
  }
</script>
