        <p class="text-text-secondary mt-3 max-w-xl">
          Interactive previews of what we can build for your industry.
        </p>
      </div>
    </div>

    <div class="flex gap-3 mb-10 overflow-x-auto pb-2" data-animate>
      {demos.map((demo, i) => (
        <button
          class={`demo-tab px-4 py-2 text-sm font-medium whitespace-nowrap transition-all duration-200 ${i === 0 ? 'bg-accent text-white' : 'text-text-secondary hover:text-text border border-border'}`}
          data-demo={demo.id}
