<button id="theme-toggle" class="relative w-12 h-7 rounded-full border border-border bg-bg-surface flex items-center transition-all duration-300 hover:border-accent/50" aria-label="Toggle theme">
  <div id="toggle-dot" class="absolute left-1 w-5 h-5 rounded-full bg-text-secondary transition-all duration-300 flex items-center justify-center">
    <svg class="w-3 h-3 dark-icon hidden text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
    <svg class="w-3 h-3 light-icon text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
  </div>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const dot = document.getElementById('toggle-dot');
  const html = document.documentElement;
  const lightIcon = toggle?.querySelector('.light-icon');
  const darkIcon = toggle?.querySelector('.dark-icon');

  function updateToggle() {
    const isDark = html.classList.contains('dark');
    if (dot) {
      dot.style.transform = isDark ? 'translateX(20px)' : 'translateX(0)';
      dot.style.background = isDark ? '#1e293b' : '#f59e0b';
    }
    if (lightIcon) lightIcon.classList.toggle('hidden', isDark);
    if (darkIcon) darkIcon.classList.toggle('hidden', !isDark);
  }

  const savedTheme = localStorage.getItem('theme');
  if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    html.classList.add('dark');
  }

  updateToggle();

  toggle?.addEventListener('click', () => {
    html.classList.toggle('dark');
    const isDark = html.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateToggle();
  });
</script>
