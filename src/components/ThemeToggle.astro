<button id="theme-toggle" class="relative w-12 h-7 rounded-full border border-border bg-bg-surface flex items-center transition-all duration-300 hover:border-accent/50 group" aria-label="Toggle dark mode">
  <div id="toggle-dot" class="absolute left-1 w-5 h-5 rounded-full bg-text-secondary transition-all duration-300 flex items-center justify-center">
    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24">
      <path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
    </svg>
  </div>
  <span class="absolute right-2 text-[10px] font-medium text-text-muted opacity-0 group-hover:opacity-100 transition-opacity">Dark</span>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const dot = document.getElementById('toggle-dot');
  const html = document.documentElement;

  function updateToggle() {
    const isDark = html.classList.contains('dark');
    if (dot) {
      dot.style.transform = isDark ? 'translateX(20px)' : 'translateX(0)';
      dot.style.background = isDark ? '#3b82f6' : '#64748b';
    }
    if (toggle) {
      toggle.style.borderColor = isDark ? '#3b82f6' : '';
      toggle.style.background = isDark ? '#1e293b' : '';
    }
  }

  const savedTheme = localStorage.getItem('theme');
  if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    html.classList.add('dark');
  }

  updateToggle();

  toggle?.addEventListener('click', () => {
    html.classList.toggle('dark');
    const isDark = html.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateToggle();
  });
</script>
