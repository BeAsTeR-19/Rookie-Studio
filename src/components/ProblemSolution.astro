---
const comparisons = [
  { typical: 'Hands you a template, calls it "custom"', us: 'We research your market before writing code' },
  { typical: 'Disappears after launch, no support', us: "We're still here after launch — optimizing, not vanishing" },
  { typical: 'Bills by the hour, scope creeps forever', us: 'Fixed-price projects, no surprise invoices' },
  { typical: 'Builds what looks good, not what converts', us: 'Every decision backed by data, not guesswork' },
];
---

<section id="services" class="py-32">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-accent text-sm font-medium mb-4 uppercase tracking-wider">Why choose us</p>
      <h2 class="text-4xl md:text-5xl font-bold font-display mb-6 tracking-tight">
        Not your typical <span class="text-accent">agency</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        We do things differently — and it shows in every project we deliver.
      </p>
    </div>

    <div class="border border-border rounded-2xl overflow-hidden bg-bg-surface" data-animate>
      <div class="grid grid-cols-[1fr_1fr] border-b border-border">
        <div class="px-6 py-4 border-r border-border bg-bg-elevated">
          <span class="text-sm font-semibold text-text-muted">The typical agency</span>
        </div>
        <div class="px-6 py-4 bg-accent/5">
          <span class="text-sm font-semibold text-accent">How we work</span>
        </div>
      </div>

      {comparisons.map((row, i) => (
        <div class={`grid grid-cols-[1fr_1fr] ${i < comparisons.length - 1 ? 'border-b border-border' : ''}`}>
          <div class="px-6 py-5 border-r border-border flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-red-500/10 flex items-center justify-center">
              <svg class="w-3 h-3 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </span>
            <span class="text-sm text-text-secondary leading-relaxed">{row.typical}</span>
          </div>
          <div class="px-6 py-5 flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-green-500/10 flex items-center justify-center">
              <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <span class="text-sm text-text font-medium leading-relaxed">{row.us}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
