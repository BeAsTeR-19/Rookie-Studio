---
import MagneticButton from './MagneticButton.astro';

const projects = [
  { name: 'PilotCompassTest.com', category: 'EdTech / SaaS', url: 'https://pilotcompasstest.com', color: '#0070F3' },
  { name: 'Arthneeti', category: 'Fintech', url: 'https://arthneeti.com', color: '#7928CA' },
  { name: 'Nepali Imposter Game', category: 'Gaming', url: '#', color: '#10B981' }
];
---

<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js"></script>

<section class="relative min-h-screen flex items-center overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-accent/3 via-transparent to-secondary/3"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-8 py-32 relative z-10">
    <div class="grid lg:grid-cols-[1fr_1.3fr] gap-8 items-center">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-bg-surface border border-border text-xs text-text-secondary mb-8" data-animate>
          <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
          Available for new projects
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold font-display leading-[1.05] tracking-tight mb-6" data-animate>
          We craft<br/>
          <span class="text-accent">digital experiences</span><br/>
          that matter
        </h1>

        <p class="text-lg text-text-secondary max-w-lg leading-relaxed mb-8" data-animate>
          Emotion is the heart of every decision. We create the digital world your brand lives in — websites, apps, and software that connect with people.
        </p>

        <div class="flex flex-col sm:flex-row gap-4" data-animate>
          <MagneticButton href="#work" class="px-7 py-3.5 text-sm font-medium text-white bg-accent hover:bg-accent-hover rounded-lg shadow-lg shadow-accent/20">
            View Our Work
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </MagneticButton>
          <a href="#contact" class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-medium text-text border border-border hover:border-text/30 rounded-lg transition-all duration-200">
            Get in Touch
          </a>
        </div>
      </div>

      <div class="relative flex justify-center items-center" data-animate>
        <div class="relative w-full" style="max-width: 700px;">
          <model-viewer
            src="/macbook_ultra_concept.glb"
            alt="MacBook showing project"
            camera-controls
            auto-rotate
            disable-zoom
            camera-orbit="25deg 72deg 1.8m"
            min-camera-orbit="auto auto auto"
            max-camera-orbit="auto auto auto"
            field-of-view="25deg"
            style="width: 100%; height: 650px; background: transparent;"
            class="macbook-viewer"
            shadow-intensity="0"
            shadow-softness="0"
            exposure="1.2"
            environment-image="neutral"
          >
            <!-- Hotspot anchored to the laptop screen surface -->
            <div
              slot="hotspot-screen"
              data-position="0 0.012 0.112"
              data-normal="0 0.3 0.95"
              data-visibility-attribute="visible"
              id="screen-content"
              style="
                width: 500px;
                height: 310px;
                transform: translateX(-50%) translateY(-50%) perspective(800px) rotateX(15deg);
                border-radius: 6px;
                overflow: hidden;
                pointer-events: none;
                background: #000;
                box-shadow: 0 4px 20px rgba(0,0,0,0.3);
              "
            >
              {projects.map((project, i) => (
                <iframe
                  src={project.url}
                  title={project.name}
                  class={`hero-iframe absolute inset-0 w-full h-full border-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}
                  data-index={i}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  style="pointer-events: none;"
                ></iframe>
              ))}
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-2">
                <div class="flex items-center gap-2 mb-1">
                  <span class="hero-project-badge px-2 py-0.5 text-xs font-medium rounded" style={`background: ${projects[0].color}30; color: ${projects[0].color}`}>
                    {projects[0].category}
                  </span>
                </div>
                <h3 class="text-xs font-bold font-display text-white hero-project-name">{projects[0].name}</h3>
              </div>
            </div>
          </model-viewer>
        </div>

        <div class="flex items-center justify-center gap-2 mt-4 absolute -bottom-8 left-0 right-0">
          {projects.map((_, i) => (
            <button
              class={`hero-dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-accent w-6' : 'bg-border hover:bg-text-muted'}`}
              data-index={i}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const projects = [
    { name: 'PilotCompassTest.com', category: 'EdTech / SaaS', url: 'https://pilotcompasstest.com', color: '#0070F3' },
    { name: 'Arthneeti', category: 'Fintech', url: 'https://arthneeti.com', color: '#7928CA' },
    { name: 'Nepali Imposter Game', category: 'Gaming', url: '#', color: '#10B981' }
  ];

  let current = 0;
  const iframes = document.querySelectorAll('.hero-iframe') as NodeListOf<HTMLElement>;
  const dots = document.querySelectorAll('.hero-dot');
  const projectName = document.querySelector('.hero-project-name');
  const projectBadge = document.querySelector('.hero-project-badge');

  function goTo(index: number) {
    if (index >= projects.length) index = 0;
    current = index;

    iframes.forEach((iframe, i) => {
      if (i === current) {
        iframe.classList.remove('opacity-0', 'pointer-events-none');
        iframe.classList.add('opacity-100');
      } else {
        iframe.classList.add('opacity-0', 'pointer-events-none');
        iframe.classList.remove('opacity-100');
      }
    });

    dots.forEach((dot, i) => {
      if (i === current) {
        dot.classList.add('bg-accent', 'w-6');
        dot.classList.remove('bg-border');
      } else {
        dot.classList.remove('bg-accent', 'w-6');
        dot.classList.add('bg-border');
      }
    });

    const p = projects[current];
    if (projectName) projectName.textContent = p.name;
    if (projectBadge) {
      projectBadge.textContent = p.category;
      projectBadge.style.background = `${p.color}30`;
      projectBadge.style.color = p.color;
    }
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.getAttribute('data-index') || '0'));
    });
  });

  setInterval(() => {
    goTo(current + 1);
  }, 5000);
</script>
