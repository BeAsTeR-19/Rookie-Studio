---
const logos = ['PilotCompass', 'AftALevel', 'NepaliImposterGame', 'Arthneeti'];

const testimonials = [
  {
    quote: "ROOKIE STUDIO built our pilot assessment platform from scratch. It handles real-time simulations, joystick input, and serves 100+ active users. The quality is exceptional.",
    name: "Amar Kumar Jayswal",
    role: "Founder, PilotCompassTest.com",
    color: "#1981C8"
  },
  {
    quote: "Our new website increased bookings by 312% in the first month. They understood our business better than we did.",
    name: "Sarah Kim",
    role: "CEO, Grand Horizon Hotels",
    color: "#7B19C8"
  },
  {
    quote: "From concept to launch in 3 weeks. The team delivered a custom e-commerce platform that exceeded all expectations. ROI was positive within the first month.",
    name: "Marcus Rodriguez",
    role: "Founder, CloudBase",
    color: "#10B981"
  }
];
---

<section class="py-24 border-t border-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <p class="text-text-muted text-sm mb-6">Trusted by teams building the future</p>
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 opacity-30">
        {logos.map((logo) => (
          <div class="text-lg font-display font-bold text-text-secondary">{logo}</div>
        ))}
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-px bg-border rounded-xl overflow-hidden" data-animate>
      {testimonials.map((t) => (
        <div class="bg-bg p-8">
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-text-secondary text-sm leading-relaxed mb-6">
            "{t.quote}"
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-xs font-bold" style={`background: ${t.color}`}>
              {t.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="text-sm font-medium">{t.name}</div>
              <div class="text-xs text-text-muted">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
