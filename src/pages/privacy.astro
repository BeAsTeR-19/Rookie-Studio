---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy | ROOKIE STUDIO" description="Privacy policy for ROOKIE STUDIO web development services.">
  <Navbar />
  <main class="pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold font-display mb-4">Privacy Policy</h1>
      <p class="text-text-muted text-sm mb-12">Last updated: June 29, 2026</p>

      <div class="prose prose-lg max-w-none space-y-8 text-text-secondary">
        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">1. Information We Collect</h2>
          <p class="leading-relaxed">When you contact us or use our services, we may collect:</p>
          <ul class="list-disc list-inside space-y-2 mt-4">
            <li>Name and email address via contact forms</li>
            <li>Project requirements and business information</li>
            <li>Payment information (processed securely via third-party providers)</li>
            <li>Browser type, IP address, and usage data via Google Analytics</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">2. How We Use Your Information</h2>
          <p class="leading-relaxed">We use collected information to:</p>
          <ul class="list-disc list-inside space-y-2 mt-4">
            <li>Communicate about your project and provide updates</li>
            <li>Deliver our web development services</li>
            <li>Process payments and send invoices</li>
            <li>Improve our website and services</li>
            <li>Send occasional updates about our services (with your consent)</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">3. Data Sharing</h2>
          <p class="leading-relaxed">We do not sell your personal information. We may share data with:</p>
          <ul class="list-disc list-inside space-y-2 mt-4">
            <li>Third-party hosting providers (Vercel, Cloudflare)</li>
            <li>Analytics services (Google Analytics)</li>
            <li>Payment processors</li>
            <li>Legal authorities when required by law</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">4. Cookies</h2>
          <p class="leading-relaxed">Our website uses essential cookies for functionality and analytics cookies to understand visitor behavior. You can control cookies through your browser settings.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">5. Data Security</h2>
          <p class="leading-relaxed">We implement industry-standard security measures to protect your data. However, no method of transmission over the internet is 100% secure.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">6. Your Rights</h2>
          <p class="leading-relaxed">You have the right to:</p>
          <ul class="list-disc list-inside space-y-2 mt-4">
            <li>Access your personal data</li>
            <li>Request correction of inaccurate data</li>
            <li>Request deletion of your data</li>
            <li>Opt out of marketing communications</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold font-display text-text mb-4">7. Contact Us</h2>
          <p class="leading-relaxed">For privacy-related inquiries, contact us at <a href="mailto:hello@rookiestudio.com" class="text-accent hover:underline">hello@rookiestudio.com</a></p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
